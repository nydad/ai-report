<mxfile host="Confluence">
  <diagram id="spoq2-pipeline" name="Spoq2 Pipeline">
    <mxGraphModel dx="1000" dy="1100" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1000" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="title" value="Spoq2 Verification Pipeline" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=22;fontStyle=1;fontColor=#92400e" vertex="1" parent="1">
          <mxGeometry x="200" y="20" width="600" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="subtitle" value="Linear flow — user setup → automated pipeline → result" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#475569" vertex="1" parent="1">
          <mxGeometry x="200" y="58" width="600" height="20" as="geometry"/>
        </mxCell>

        <mxCell id="phase1-bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fffbeb;strokeColor=#92400e;strokeWidth=2" vertex="1" parent="1">
          <mxGeometry x="60" y="100" width="880" height="180" as="geometry"/>
        </mxCell>
        <mxCell id="phase1-label" value="PHASE 1 — USER SETUP (manual)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=12;fontStyle=1;fontColor=#92400e" vertex="1" parent="1">
          <mxGeometry x="80" y="110" width="400" height="24" as="geometry"/>
        </mxCell>

        <mxCell id="u-src" value="Unmodified C source code" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#92400e;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="90" y="150" width="250" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="u-cfg" value="Machine + Pointer Config&#10;(Coq records)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#92400e;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="375" y="150" width="250" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="u-inv" value="★ Inductive Invariant&#10;(security property)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fed7aa;strokeColor=#92400e;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="660" y="150" width="250" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="phase1-note" value="★ 가장 노동집약적 — 시스템 지식 + 형식 기법 양쪽 필요" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=11;fontStyle=2;fontColor=#92400e" vertex="1" parent="1">
          <mxGeometry x="80" y="230" width="840" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="arrow1" style="edgeStyle=none;rounded=0;html=1;endArrow=classic;endFill=1;strokeColor=#64748b;strokeWidth=3" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="500" y="280" as="sourcePoint"/>
            <mxPoint x="500" y="320" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <mxCell id="phase2-bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#2c5282;strokeWidth=2" vertex="1" parent="1">
          <mxGeometry x="60" y="330" width="880" height="620" as="geometry"/>
        </mxCell>
        <mxCell id="phase2-label" value="PHASE 2 — AUTOMATED PIPELINE (Spoq2 tool)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=12;fontStyle=1;fontColor=#2c5282" vertex="1" parent="1">
          <mxGeometry x="80" y="340" width="500" height="24" as="geometry"/>
        </mxCell>

        <mxCell id="s1" value="Step 1 — Clang:   C  →  LLVM IR" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2c5282;fontSize=13;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="200" y="380" width="600" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="a2" style="edgeStyle=none;rounded=0;html=1;endArrow=classic;endFill=1;strokeColor=#2c5282;strokeWidth=2;exitX=0.5;exitY=1;entryX=0.5;entryY=0" edge="1" parent="1" source="s1" target="s2">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="s2" value="Step 2 — LLVM IR  →  Coq (Rocq) embedding" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2c5282;fontSize=13" vertex="1" parent="1">
          <mxGeometry x="200" y="450" width="600" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="a3" style="edgeStyle=none;rounded=0;html=1;endArrow=classic;endFill=1;strokeColor=#2c5282;strokeWidth=2;exitX=0.5;exitY=1;entryX=0.5;entryY=0" edge="1" parent="1" source="s2" target="s3">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="s3" value="Step 3 — Inline Transformation (self-contained transitions)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2c5282;fontSize=13" vertex="1" parent="1">
          <mxGeometry x="200" y="520" width="600" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="a4" style="edgeStyle=none;rounded=0;html=1;endArrow=classic;endFill=1;strokeColor=#2c5282;strokeWidth=2;exitX=0.5;exitY=1;entryX=0.5;entryY=0" edge="1" parent="1" source="s3" target="s4">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="s4" value="Step 4 — Invariant Enumeration (path + SMT query generation)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2c5282;fontSize=13" vertex="1" parent="1">
          <mxGeometry x="200" y="590" width="600" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="a5" style="edgeStyle=none;rounded=0;html=1;endArrow=classic;endFill=1;strokeColor=#2c5282;strokeWidth=2;exitX=0.5;exitY=1;entryX=0.5;entryY=0" edge="1" parent="1" source="s4" target="s5">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="s5" value="Step 5 — ① Per-Transition Cone-of-Influence pruning" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#93c5fd;strokeColor=#1e40af;fontSize=13;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="200" y="660" width="600" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="a6" style="edgeStyle=none;rounded=0;html=1;endArrow=classic;endFill=1;strokeColor=#2c5282;strokeWidth=2;exitX=0.5;exitY=1;entryX=0.5;entryY=0" edge="1" parent="1" source="s5" target="s6">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="s6" value="Step 6 — ② Pointer Abstraction (bit-vec → property access)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#93c5fd;strokeColor=#1e40af;fontSize=13;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="200" y="730" width="600" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="a7" style="edgeStyle=none;rounded=0;html=1;endArrow=classic;endFill=1;strokeColor=#2c5282;strokeWidth=2;exitX=0.5;exitY=1;entryX=0.5;entryY=0" edge="1" parent="1" source="s6" target="s7">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="s7" value="Step 7 — ③ Z3 SMT Solve  +  Query Cache" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#93c5fd;strokeColor=#1e40af;fontSize=13;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="200" y="800" width="600" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="phase2-note" value="①②③ = Spoq2의 3대 핵심 최적화" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=11;fontStyle=2;fontColor=#1e40af" vertex="1" parent="1">
          <mxGeometry x="80" y="880" width="840" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="arrow-out" style="edgeStyle=none;rounded=0;html=1;endArrow=classic;endFill=1;strokeColor=#64748b;strokeWidth=3" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="500" y="950" as="sourcePoint"/>
            <mxPoint x="500" y="990" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <mxCell id="phase3-bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0fdf4;strokeColor=#276749;strokeWidth=2" vertex="1" parent="1">
          <mxGeometry x="60" y="1000" width="880" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="phase3-label" value="PHASE 3 — RESULT" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=12;fontStyle=1;fontColor=#276749" vertex="1" parent="1">
          <mxGeometry x="80" y="1006" width="300" height="20" as="geometry"/>
        </mxCell>

        <mxCell id="r-pass" value="✓ PASS — property proven" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#bbf7d0;strokeColor=#276749;fontSize=13;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="90" y="1035" width="400" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="r-fail" value="✗ FAIL — counterexample (e.g. SeKVM lock-race ×2)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fecaca;strokeColor=#991b1b;fontSize=13;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="510" y="1035" width="400" height="40" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
